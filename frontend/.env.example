# =============================================================================
# REQUIRED — no defaults, build will fail without these
# =============================================================================

# Stytch public token for SDK initialization
VITE_STYTCH_PUBLIC_TOKEN=public-token-test-your-token-here

# Numia API token
VITE_NUMIA_TOKEN=your-numia-token-here

# Network selector: "testnet" | "mainnet" | "devnet"
# Drives which config is loaded from src/config/
VITE_NETWORK=testnet

# Wrangler environment selector (used by Cloudflare Vite plugin / wrangler dev)
CLOUDFLARE_ENV=testnet

# =============================================================================
# OPTIONAL — all have defaults in src/config/testnet.ts and mainnet.ts
# Only set these to override the hardcoded config values for local development.
# =============================================================================

# Chain
# VITE_CHAIN_ID=xion-testnet-2

# API URLs
# VITE_XION_API_URL=https://api.xion-testnet-2.burnt.com
# VITE_XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com
# VITE_XION_STYTCH_API=https://stytch.testnet.burnt.com/v1
# VITE_ABSTRAXION_API_URL=https://aa-api.testnet.burnt.com
# VITE_ZKEMAIL_BACKEND_URL=https://zk-api.testnet.burnt.com

# Indexer
# VITE_INDEXER_STRATEGY=numia
# VITE_DEFAULT_INDEXER_URL=https://api.subquery.network/sq/burnt-labs/xion-testnet-2-indexer
# VITE_NUMIA_URL=https://xion-testnet-2.numia.xyz/v3/

# Account configuration
# VITE_FEE_GRANTER_ADDRESS=xion1xrqz2wpt4rw8rtdvrc4n4yn5h54jm0nn4evn2x
# VITE_DEFAULT_ACCOUNT_CONTRACT_CODE_ID=1

# Gas
# VITE_GAS_ADJUSTMENT=1.8
# VITE_GAS_MARGIN=5000

# Feature flags (override network defaults)
# VITE_KEPLR_FLAG=true
# VITE_METAMASK_FLAG=true
# VITE_OKX_FLAG=true
# VITE_PASSKEY_FLAG=true
# VITE_APPLE_FLAG=true
# VITE_TIKTOK_FLAG=false
# VITE_ZKEMAIL_FLAG=true

# Cloudflare Turnstile (CAPTCHA)
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAACUOXqmE31xhK_y8

# ZK-Email allowed host
# VITE_ZK_EMAIL_RECEIVER_EMAIL_ID=zkauth@zk.burnt.com
